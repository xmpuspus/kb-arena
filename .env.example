# KB Arena Environment Configuration
# Copy to .env and fill in your values

# Required: Anthropic API key for LLM calls
KB_ARENA_ANTHROPIC_API_KEY=sk-ant-...

# Neo4j (defaults work with docker-compose)
KB_ARENA_NEO4J_URI=bolt://localhost:7687
KB_ARENA_NEO4J_USER=neo4j
KB_ARENA_NEO4J_PASSWORD=kbarena

# ChromaDB storage path
KB_ARENA_CHROMA_PATH=./chroma_data

# LLM models
KB_ARENA_GENERATE_MODEL=claude-sonnet-4-6
KB_ARENA_FAST_MODEL=claude-haiku-4-5-20251001

# Embedding model
KB_ARENA_EMBEDDING_MODEL=text-embedding-3-small

# Server
KB_ARENA_HOST=0.0.0.0
KB_ARENA_PORT=8000
KB_ARENA_DEBUG=false
