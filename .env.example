# KB Arena Environment Configuration
# Copy to .env and fill in your values

# Required: Anthropic API key for LLM calls (claude-sonnet-4-6, claude-haiku-4-5)
KB_ARENA_ANTHROPIC_API_KEY=sk-ant-...

# Required: OpenAI API key for embeddings (text-embedding-3-large)
OPENAI_API_KEY=sk-...

# Neo4j (defaults work with docker-compose)
KB_ARENA_NEO4J_URI=bolt://localhost:7687
KB_ARENA_NEO4J_USER=neo4j
KB_ARENA_NEO4J_PASSWORD=kbarena

# ChromaDB storage path
KB_ARENA_CHROMA_PATH=./chroma_data

# LLM models (latest Anthropic models)
KB_ARENA_GENERATE_MODEL=claude-sonnet-4-6
KB_ARENA_FAST_MODEL=claude-haiku-4-5-20251001

# Embedding model (latest OpenAI embedding model, 3072 dimensions)
KB_ARENA_EMBEDDING_MODEL=text-embedding-3-large
KB_ARENA_EMBEDDING_DIMENSIONS=3072

# Server
KB_ARENA_HOST=0.0.0.0
KB_ARENA_PORT=8000
KB_ARENA_DEBUG=false
