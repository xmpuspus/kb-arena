# Required — LLM and embeddings
KB_ARENA_ANTHROPIC_API_KEY=sk-ant-...
KB_ARENA_OPENAI_API_KEY=sk-...

# Optional — Neo4j (defaults shown)
# KB_ARENA_NEO4J_URI=bolt://localhost:7687
# KB_ARENA_NEO4J_USER=neo4j
# KB_ARENA_NEO4J_PASSWORD=kbarena1

# Optional — ChromaDB
# KB_ARENA_CHROMA_PATH=./chroma_data

# Optional — embedding model
# KB_ARENA_EMBEDDING_MODEL=text-embedding-3-large
# KB_ARENA_EMBEDDING_DIMENSIONS=3072

# Optional — LLM model overrides
# KB_ARENA_GENERATE_MODEL=claude-sonnet-4-6
# KB_ARENA_FAST_MODEL=claude-haiku-4-5-20251001

# Optional — server
# KB_ARENA_HOST=0.0.0.0
# KB_ARENA_PORT=8000
# KB_ARENA_DEBUG=false

# Optional — benchmark tuning
# KB_ARENA_BENCHMARK_TEMPERATURE=0.0
# KB_ARENA_BENCHMARK_MAX_CONCURRENT=5
# KB_ARENA_BENCHMARK_QUERY_TIMEOUT_S=120
# KB_ARENA_BENCHMARK_MAX_RETRIES=2

# Optional — paths
# KB_ARENA_DATASETS_PATH=./datasets
# KB_ARENA_RESULTS_PATH=./results
